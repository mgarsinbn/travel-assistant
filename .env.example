# Anthropic API key for Claude AI assistant
ANTHROPIC_API_KEY=

# Google OAuth2 credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auth — only these emails can log into Umfufu (comma-separated)
ALLOWED_EMAILS=mike@example.com,alexis@example.com

# Base URL (set to your Railway URL in production)
BASE_URL=http://localhost:3000

# Session secret (auto-generated if not set, but set one for persistence across restarts)
SESSION_SECRET=

# Delta Airlines credentials (for booking flights)
DELTA_USERNAME=
DELTA_PASSWORD=

# Marriott Bonvoy credentials (for booking hotels)
MARRIOTT_USERNAME=
MARRIOTT_PASSWORD=
